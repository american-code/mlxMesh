bin/
dist/
*.test
*.out
vendor/
.env
~/.config/oim/node_identity.json
certs/
# Compiled binaries occasionally land at repo root from a bare `go build -o
# <name> ./cmd/...` run outside bin/ — never intended to be committed.
/jobgen
/stub-exo
/oim
/oim-coordinator
/oim-directory
*.bck.yml

# OIMMenuBar: the embedded oim binary is built fresh by scripts/embed-oim.sh
# before every `xcodegen generate` (see that script + project.yml) — never
# intended to be committed. The generated .xcodeproj IS committed (matching
# OIMDashboard's convention), just not this binary or Xcode's user-state cruft.
OIMMenuBar/Resources/oim
OIMMenuBar/**/xcuserdata/
OIMMenuBar/**/*.xcuserstate
